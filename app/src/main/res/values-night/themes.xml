<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Base application theme -->
    <style name="Theme.NetGuard"
        parent="Theme.MaterialComponents.DayNight.DarkActionBar">

        <!-- Primary colors -->
        <item name="colorPrimary">@color/accent_cyan</item>
        <item name="colorPrimaryVariant">@color/surface_dark</item>
        <item name="colorOnPrimary">@android:color/white</item>

        <!-- Secondary colors -->
        <item name="colorSecondary">@color/success_green</item>
        <item name="colorSecondaryVariant">@color/warning_orange</item>
        <item name="colorOnSecondary">@android:color/white</item>

        <!-- Background -->
        <item name="android:windowBackground">@color/bg_dark</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">@color/surface_dark</item>

    </style>

</resources>